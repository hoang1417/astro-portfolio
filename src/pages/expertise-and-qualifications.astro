---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Henry Le | Technical Business Analyst - Data & Operations Specialist" 
  description="Henry Le helps manufacturing and distribution businesses improve operations through data analytics, system integration, and business process optimisation."
>
	<div class="stack gap-20">
		<main class="wrapper about">
			
			<Hero 
				title="Technical Business Analyst | Data & Operations Specialist"
				tagline="I help manufacturing, retail, and distribution businesses improve operational efficiency, automate reporting, and enhance customer management through data analytics, process improvements, and system integration."
			/>

			<section>
				<h2 class="section-title">Experience</h2>
				<div class="content">
					<p><strong>9+ years</strong> in ICT Business Analysis delivering system and process improvements</p>
					<p><strong>4+ years</strong> in Data Analytics driving reporting automation and insights</p>
					<p><strong>11+ years</strong> in Software Development across enterprise and business systems</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Core Capabilities</h2>
				<div class="content">
					<p><strong>Data Analytics & Decision Support</strong></p>
					<p class="indent">Transform raw data into actionable insights using BI tools and structured data models</p>
					<p><strong>Business Process Optimisation</strong>
					<p class="indent">Analyse and redesign workflows to reduce manual effort and inefficiencies</p>
					<p><strong>ERP & CRM Systems</strong>
					<p class="indent">Implement and enhance enterprise systems to improve operations and customer management</p>
					<p><strong>System Architecture & Integration</strong></p>
					<p class="indent">Design scalable systems and API integrations across platforms</p>
					<p><strong>Business & Systems Analysis</strong></p>
					<p class="indent">Bridge business needs with technical implementation across cross-functional teams</p>
				</div>
			</section>
			
			<section>
				<h2 class="section-title">Industry Focus</h2>
				<div class="content">
					<p><strong>Logistics</strong>: Shipment tracking, Shipping line analysis, route optimisation, and system integration</p>
					<p><strong>Retail & Wholesale</strong>: Order management, pricing, customer lifecycle, and sales operations</p>
					<p><strong>E-commerce</strong>: Platform integration, data flows, and digital order processing</p>
					<p><strong>Manufacturing</strong>: Quality control, production processes, and operational efficiency</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p><strong>MBA</strong> from Western Sydney University</p>
					<p><strong>Bachelor of Engineering in Computer Science</strong> from Vietnam National University of Technology</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Certifications</h2>
				<div class="content">
					<p>Microsoft Fabric Analytics Engineer - AI Skills Challenge (Microsoft)</p>
					<p>Agile Project Management - Scrum, Kanban & XP (GenMan Solutions)</p>
					<p>Product-Led Certification (Pendo)</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">How I Create Value</h2>
				<div class="content">
					<p>• Reduce manual reporting and operational overhead through automation</p>
					<p>• Improve data visibility for faster and more accurate decision-making</p>
					<p>• Align business requirements with scalable technical solutions</p>
					<p>• Deliver practical, business-focused outcomes—not just technical outputs</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Selected Impact</h2>
				<div class="content">
					<p><strong>Automated Reporting System</strong>: Developed automated data processing and reporting system to update customers regarding the company service's status which saved 10% of sales operation hours every week.</p>
					<p><strong>Automated Shipment Information Update</strong>: Built automation programs using Python, Azure Function App, Azure Logic App, and Azure infrastructure to update Shipment information from external data sources which saved 20% logistics operation hours every week and gained near real-time data update cadence.</p>
					<p><strong>Operational Efficiency Improvement</strong>: Implemented and rolled out the new core logistics system to ASEAN countries that shortened average delivery lead time by 20%.</p>
					<p><strong>Process Digitalisation</strong>: Digitalised order form generation process involving multiple stakeholders like supplier managers, sales, logistics in a centralised and robust platform which reduced 30% of communication overhead.</p>
				</div>
			</section>

		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;

		.tagline {
			font-size: var(--text-l);
		}
	}


	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
		p {
  			text-indent: -1.5rem;
		}
		p.indent {
			margin-left: 1.5rem;
		}
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
