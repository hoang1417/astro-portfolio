---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import "@fortawesome/fontawesome-free/css/all.min.css";
import Icon from '../components/Icon.astro';
import ImagePopup from '../components/ImagePopup.astro';
import CallToAction from '../components/CallToAction.astro';

---

<BaseLayout 
  title="Henry Le | Technical Business Analyst - Data & Operations Specialist" 
  description="Henry Le helps manufacturing and distribution businesses improve operations through data analytics, system integration, and business process optimisation."
>
	<div class="stack">
		<main class="wrapper about">
			
			<Hero 
				title="Technical Business Analyst | Data & Operations Specialist"
				tagline="I help manufacturing, retail, and distribution businesses improve operational efficiency, automate reporting, and gain real-time visibility through automation, data analytics, and system integration."
			/>

			<section>
				<h2 class="section-title">Experience</h2>
				<div class="content">
					<p><strong>9+ years</strong> in <strong><i>ICT Business Analysis</i></strong> delivering system and process improvements</p> 
					<p><strong>4+ years</strong> in <strong><i>Data Analytics</i></strong> driving reporting automation and insights</p>
					<p><strong>11+ years</strong> in <strong><i>Software Development</i></strong> across enterprise and business systems</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Core Capabilities</h2>
				<div class="content">
					<p><strong>Data Analytics & Decision Support (SQL, Power BI)</strong> <Icon icon="speedometer" size="1.33em"/></p>
					<p class="indent">Transform raw data into actionable insights using BI tools and structured data models</p>
					<p><strong>Business Process Optimisation</strong> <Icon icon="network" size="1.33em"/></p>
					<p class="indent">Analyse and redesign workflows to reduce manual effort and inefficiencies</p>
					<p><strong>ERP & CRM Systems (SAP, Microsoft ecosystem)</strong> <Icon icon="warehouse" size="1.33em" /></p>
					<p class="indent">Implement and enhance enterprise systems to improve operations and customer management</p>
					<p><strong>System Architecture & Integration (Azure)</strong> <Icon icon="database" size="1.33em" /></p>
					<p class="indent">Design scalable systems and API integrations across platforms</p>
					<p><strong>Business & Systems Analysis</strong> <Icon icon="handshake" size="1.33em" /></p>
					<p class="indent">Bridge business needs with technical implementation across cross-functional teams</p>
				</div>
			</section>
			
			<section>
				<h2 class="section-title">Industry Focus</h2>
				<div class="content">
					<p><strong>Logistics <Icon icon="truck" size="1.33em" /></strong>: Shipment tracking, Shipping line analysis, route optimisation, and system integration</p>
					<p><strong>Retail & Wholesale <Icon icon="store-front" size="1.33em" /></strong>: Order management, pricing, customer lifecycle, and sales operations</p>
					<p><strong>E-commerce <Icon icon="shopping-cart" size="1.33em" /></strong>: Platform integration, data flows, and digital order processing</p>
					<p><strong>Manufacturing <Icon icon="factory" size="1.33em" /></strong>: Quality control, production processes, and operational efficiency</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<ImagePopup 
						items={[
							{
								content: "<strong>MBA</strong> from Western Sydney University",
								image: "/assets/certificates/MBA - Master of Business Administration.jpg"
							},
							{
								content: "<strong>Bachelor of Engineering in Computer Science</strong> from Vietnam National University of Technology",
								image: "/assets/certificates/Bachelor of Engineering in Computer Science.jpg"
							}
						]}
					/>
				</div>
			</section>

			<section>
				<h2 class="section-title">Certifications</h2>
				<div class="content">
					<ImagePopup 
						items={[
							{
								content: "<strong>Business Analysis Fundamentals</strong> - ECBA, CCBA, CBAP endorsed (The BA Guide)",
								image: "/assets/certificates/Business Analysis Fundamentals - The BA Guide.png"
							},
							{
								content: "<strong>Product-led Certified</strong> (Pendo)",
								image: "/assets/certificates/Product-led Certified - Pendo.png"
							},
							{
								content: "<strong>AI Job Simulation</strong> (Cognizant)",
								image: "/assets/certificates/AI Job Simulation - Cognizant.png"
							}
						]}
					/>
				</div>
			</section>

			<section>
				<h2 class="section-title">Technical Skills</h2>
				<div class="content">
					<p><strong>Business & Systems</strong></p>
					<p>• ERP optimisation (SAP, Oracle) to streamline operational workflows and improve system efficiency</p>
					<p>• Process analysis, mapping, and optimisation to eliminate inefficiencies and standardise operations</p>

					<p class="skill-title"><strong>Reporting & Insights</strong></p>
					<p>• Power BI, Tableau (operational dashboards, KPI tracking, and decision-support reporting)</p>

					<p class="skill-title"><strong>Data & Engineering</strong></p>
					<p>• SQL (data wrangling, data modelling, and performance optimisation for large datasets)</p>
					<p>• Python (process automation, ETL pipelines, and data transformation)</p>
					<p>• MS SQL Server, PostgreSQL, MongoDB (data management, security, and performance optimisation)</p>

					<p class="skill-title"><strong>Automation & Integration</strong></p>
					<p>• End-to-end workflow automation using Python, Excel VBA, and APIs to reduce manual workload and reporting time</p>
					<p>• System integration and tool development using Git and modern development practices</p>

					<p class="skill-title"><strong>Tools & Collaboration</strong></p>
					<p>• Diagrams.net, Lucidchart, Figma (process modelling and system design)</p>
					<p>• Jira, Confluence, MS Office (stakeholder collaboration and documentation)</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">How I Create Value</h2>
				<div class="content">
					<p>• Reduce manual reporting and operational overhead through automation</p>
					<p>• Improve data visibility for faster and more accurate decision-making</p>
					<p>• Align business requirements with scalable technical solutions</p>
					<p>• Deliver practical, business-focused outcomes—not just technical outputs</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Selected Impact</h2>
				<div class="content">
					<div class="capability">
						<p><strong>Automated Reporting System</strong> <Icon icon="article" size="1.33em"/></p>
						<p class="indent">Reduced sales operations workload by 12% by implementing automated reporting for real-time service status updates (order status, shipping arrival time, delivery status, etc.).</p>
					</div>

					<div class="capability">
						<p><strong>Shipment Tracking Automation</strong> <Icon icon="boat" size="1.33em"/></p>
						<p class="indent">Reduced logistics operations effort by 20% and enabled near real-time shipment visibility by building automated data integration with shipping lines and data providers.</p>
					</div>

					<div class="capability">
						<p><strong>Logistics System Rollout</strong> <Icon icon="van" size="1.33em"/></p>
						<p class="indent">Improved operational efficiency and reduced delivery lead time by 15% by implementing and scaling a core logistics system across ASEAN countries.</p>
					</div>

					<div class="capability">
						<p><strong>Process Digitalisation</strong> <Icon icon="head-circuit" size="1.33em"/></p>
						<p class="indent">Reduced communication overhead by over 30% by digitising multi-stakeholder order workflows into a centralised platform.</p>
					</div>
				</div>
			</section>
			
		</main>

		<div class="lets-connect wrapper stack gap-2" style="padding: 2rem 0 5rem 0;">
			<div class="cta-section">
				<h4> Let's Connect </h4>
				<p>
					I bring a unique blend of technical expertise and business insight, with a strong focus on delivering practical, data-driven solutions. 
					I thrive in fast-paced environments where technology can drive meaningful operational improvements and business outcomes.
					
					If you're looking for someone who can bridge the gap between business needs and technical execution, I'd be glad to connect and discuss how I can contribute.
				</p>
				
				<div class="cta-button-wrapper" style="margin-top: 1rem;">
					<CallToAction href="https://www.linkedin.com/in/henry-le-ict/" blank>
						Connect on LinkedIn
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</div>
		</div>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.wrapper {
		padding-inline: 3rem;
		.section-title {
			text-align: center;
		}
	}

	.about {
		display: flex;
		flex-direction: column;
		gap: 1rem 3.5rem;

		.tagline {
			font-size: var(--text-l);
		}
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
		p {
			text-indent: -1.5rem;
			text-align: justify;
		}
		p.indent {
			text-indent: 0; /* just offset the default indent */
		}
		button {
			text-indent: -1.5rem;
		}
		.skill-title {
			padding-top: 0.5rem;
		}
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 20% 60% 10% 10%;
			
			.content {
				grid-column: 2 / 4;
			}
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}

	.cta-section {
		padding-top: 2rem;
		p {
			text-align: justify;
		}
		.cta-button-wrapper {
			a {
				display: flow;
			}
		}
	}
	
	@media (min-width: 50em) {
		.cta-section {
			p {
				font-size: 1.25rem;
				text-align: justify;
			}
			.cta-button-wrapper {
				a {
					display: inline-flex;
				}
			}
		}
	}
</style>
