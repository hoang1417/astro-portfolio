---
interface Item {
  label: string;
  image: string;
}

const { items } = Astro.props as { items: Item[] };
---

<div class="cert-list">
  {items.map((item) => (
    <button class="clickable" data-image={item.image}>
      {item.label}
    </button>
  ))}
</div>

<!-- Popup -->
<div id="popup" class="popup">
  <span class="close" role="button" tabindex="0">&times;</span>
  <img id="popupImg" alt="Certificate preview" />
</div>

<script>
    const popup = document.getElementById("popup");
    const popupImg = document.getElementById("popupImg");
    const closeBtn = document.querySelector(".close");

    if (!popup || !popupImg || !closeBtn) {
        console.warn("Popup elements not found");
    } else {
        document.querySelectorAll(".clickable").forEach((el) => {
        if (!(el instanceof HTMLElement)) return;

        el.addEventListener("click", () => {
            const img = el.dataset?.image;
            if (!img) return;

            if (popup instanceof HTMLElement && popupImg instanceof HTMLImageElement) {
                popup.style.display = "block";
                popupImg.src = img;
            }
        });
    });

    closeBtn.addEventListener("click", () => {
        popup.style.display = "none";
    });

    popup.addEventListener("click", (e) => {
        if (e.target === popup && popup instanceof HTMLElement) {
            popup.style.display = "none";
        }
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && popup instanceof HTMLElement) {
            popup.style.display = "none";
        }
    });
  }
</script>

<style>
  .cert-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .clickable {
    background: none;
    border: none;
    color: var(--gray-200);
    text-align: left;
    cursor: pointer;
    font: inherit;
    padding: 0;
    transition: opacity 0.2s ease;
  }

  .clickable:hover {
    opacity: 0.7;
  }

  /* Popup */
  .popup {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 1000;
    animation: fadeIn 0.2s ease;
  }

  .popup img {
    display: block;
    margin: auto;
    max-width: 85%;
    max-height: 85%;
    margin-top: 5%;
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
  }

  .close {
    position: absolute;
    top: 20px;
    right: 30px;
    font-size: 32px;
    color: white;
    cursor: pointer;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>